# ── Auth (obligatoire) ─────────────────────────────────────────────
# Emails autorisés à utiliser l'app (séparés par des virgules).
# Tous les endpoints API refusent les comptes hors de cette liste.
ALLOWED_EMAILS=moustickprod@gmail.com

# ── Firebase ───────────────────────────────────────────────────────
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=moustikprod-crm.firebaseapp.com
FIREBASE_PROJECT_ID=moustikprod-crm
# Clé JSON du compte de service Google (Firestore côté serveur :
# signatures, ingestion d'idées, partage projet).
FIREBASE_SERVICE_ACCOUNT_KEY=

# ── APIs externes ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=
NOTION_TOKEN=
BREVO_API_KEY=

# ── Tâches automatiques ────────────────────────────────────────────
IDEAS_INGEST_SECRET=
STUDIO_OWNER_EMAIL=moustickprod@gmail.com
