rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /clients/{clientId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /projets/{projetId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /idees/{ideeId} {
        // Lecture/suppression réservées au propriétaire connecté.
        allow read, delete: if request.auth != null && request.auth.uid == userId;
        // Écriture refusée depuis le client : seule la fonction serverless
        // /api/ideas-ingest.js (compte de service Google, hors Firestore Auth)
        // peut créer/modifier ces documents via l'API REST authentifiée OAuth2.
        allow create, update: if false;
      }
      // Tout le reste (settings, devisListe, factures, transactions, catalogue,
      // contrats, autorisations, musiques, etc.) reste sous la règle générique
      // propriétaire ci-dessus, mais explicite plutôt que via un wildcard
      // récursif fourre-tout. Un match sur le document /users/{userId} seul ne
      // couvre PAS ses sous-collections en Firestore — chacune doit être listée.
      match /data/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /catalogue/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /contrats/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /autorisations/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /musiques/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Collections utilisées uniquement par les fonctions serverless du CRM
    // (liens de signature, mapping d'abonnements Stripe), authentifiées via
    // un compte de service Google (IAM) qui contourne ces règles. Aucun client
    // (navigateur, app) ne doit jamais y accéder directement.
    match /signatureRequests/{token} {
      allow read, write: if false;
    }
    match /stripeSubscriptions/{subId} {
      allow read, write: if false;
    }
  }
}
